rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: lectura pública; cada quien escribe su propio perfil.
    // stats/achievements idealmente sólo via Cloud Functions (en MVP el cliente
    // puede escribir sus propias stats; endurecer al introducir Functions).
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Levels: cualquiera lee; el autor crea/edita/borra los suyos no verificados.
    match /levels/{levelId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.authorId == request.auth.uid
                    && resource.data.isVerified != true;
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid
                    && resource.data.isOfficial != true;
    }

    // Scores: lectura pública. En MVP (sin Cloud Functions) el usuario escribe
    // su propia entrada; con Functions/anti-cheat pasará a `allow write: if false`.
    match /scores/{levelId}/entries/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard cache: sólo lectura (lo escribe el backend).
    match /leaderboard_cache/{levelId} {
      allow read: if true;
      allow write: if false;
    }

    // Eventos (daily/weekly/challenge): sólo lectura para clientes.
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
